<!doctype html>
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml"
    xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
    <title>Staff Account Request</title>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style type="text/css">
        body { margin: 0; padding: 0; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
        table, td { border-collapse: collapse; mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
        img { border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; -ms-interpolation-mode: bicubic; }
        p { display: block; margin: 13px 0; }
        a { text-decoration: none; color: #076482; }
    </style>
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,500,700" rel="stylesheet" type="text/css">
    <style type="text/css">
        @import url(https://fonts.googleapis.com/css?family=Open+Sans:300,400,500,700);
    </style>
    <style type="text/css">
        @media only screen and (max-width:480px) {
            table.mj-full-width-mobile { width: 100% !important; }
            td.mj-full-width-mobile { width: auto !important; }
        }
    </style>
</head>
<body style="background-color:#E7E7E7;">
    <div style="background-color:#E7E7E7;">
        <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation">
            <tbody>
                <tr>
                    <td>
                        <div style="margin:0px auto;max-width:600px;">
                            <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation"
                                style="width:100%;">
                                <tbody>
                                    <tr>
                                        <td align="center" style="padding:0;word-break:break-word;">
                                            <a href="https://cedcommerce.com/" title="Cedcommerce" target="_blank">
                                                <img alt="Cedcommerce" height="auto" src="https://i.imgur.com/nCgVOdk.png"
                                                    style="border:0;display:block;outline:none;text-decoration:none;height:auto;width:100%;font-size:13px;background-color: #071042;" width="600">
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="direction:ltr;padding:20px 0;padding-bottom:0;padding-top:0;text-align:center;">
                                            <div style="background:f6f6f6;background-color:f6f6f6;margin:0px auto;max-width:600px;">
                                                <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation"
                                                    style="background:f6f6f6;background-color:f6f6f6;width:100%;">
                                                    <tbody>
                                                        <tr>
                                                            <td align="left" style="padding:10px 25px;padding-right:25px;padding-left:25px;word-break:break-word;">
                                                                <div style="font-family:open Sans Helvetica, Arial, sans-serif;font-size: 17px;font-weight: 600;line-height:26px;text-align:left;color: #1e2281;">
                                                                    Hello {{name}},
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td align="left" style="padding:10px 25px;padding-right:25px;padding-left:25px;word-break:break-word;">
                                                                <div style="font-family:open Sans Helvetica, Arial, sans-serif;font-size: 22px;font-weight: 400;line-height: 37px;text-align:left;color: #1e2281;">
                                                                    Greetings from <strong>CedCommerce!!</strong>
                                                                    <br>
                                                                    You have received a request to add <strong>{{staff_name}}</strong> as a staff member for your account.
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        
                                                        <tr>
                                                            <td align="left" style="padding: 0px 25px;word-break:break-word;">
                                                                <div style="font-family: serif;font-size: 16px;font-weight: 400;line-height: 24px;text-align:left;color: #322c32;margin-top: 11px;">
                                                                    If you did not request this action, please ignore this email or reply to let us know.
                                                                    <br>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td align="left" style="padding:10px 25px;padding-right:25px;padding-bottom:0;padding-left:25px;word-break:break-word;">
                                                                <div style="font-family:open Sans Helvetica, Arial, sans-serif;font-size: 15px;font-weight: 600;line-height:26px;text-align:left;color:#2c2c2c;">
                                                                    Best Regards,
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td align="left" style="padding:10px 25px;padding-top:0;padding-right:25px;padding-left:25px;word-break:break-word;">
                                                                <div style="font-family:open Sans Helvetica, Arial, sans-serif;font-size: 15px;font-weight: 600;line-height:26px;text-align:left;color:#2c2c2c;">
                                                                    Team CedCommerce
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation"
                                                style="background-color: #d9e6f3;width:100%;">
                                                <tbody>
                                                    <tr>
                                                        <td>
                                                            <div style="margin:0px auto;max-width:600px;">
                                                                <table align="center" border="0" cellpadding="0" cellspacing="0"
                                                                    role="presentation" style="width:100%;">
                                                                    <tbody>
                                                                        <tr>
                                                                            <td style="direction:ltr;padding:20px 0;text-align:center;">
                                                                                <div style="text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;">
                                                                                    <table border="0" cellpadding="0" cellspacing="0"
                                                                                        role="presentation" style="vertical-align:top;"
                                                                                        width="100%">
                                                                                        <tbody>
                                                                                            <tr>
                                                                                                <td align="center"
                                                                                                    style="padding:10px 25px;word-break:break-word;">
                                                                                                    <table border="0" cellpadding="0"
                                                                                                        cellspacing="0"
                                                                                                        role="presentation"
                                                                                                        style="border-collapse:collapse;border-spacing:0px;">
                                                                                                        <tbody>
                                                                                                            <tr>
                                                                                                                <td style="width:50px;">
                                                                                                                    <img alt="Ticket"
                                                                                                                        height="auto"
                                                                                                                        src="https://i.imgur.com/Ss43PIC.png"
                                                                                                                        style="border:0;display:block;outline:none;text-decoration:none;height:auto;width:100%;font-size:13px;"
                                                                                                                        width="50">
                                                                                                                </td>
                                                                                                            </tr>
                                                                                                        </tbody>
                                                                                                    </table>
                                                                                                </td>
                                                                                            </tr>
                                                                                            <tr>
                                                                                                <td align="center"
                                                                                                    style="padding:10px 25px;padding-bottom:10px;word-break:break-word;">
                                                                                                    <div
                                                                                                        style="font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size: 14px;font-weight:400;text-align:center;color:#9da3a3;">
                                                                                                        <span
                                                                                                            style="font-size: 17px;color: #000000;">Ticket</span>
                                                                                                        <br>
                                                                                                        <br>
                                                                                                        <a style="text-decoration:none;font-size:14px;display:inline-block;line-height:20px;color: #076482;"
                                                                                                            href="https://support.cedcommerce.com/open.php"
                                                                                                            target="_blank">Raise your ticket get Technical Support</a>
                                                                                                    </div>
                                                                                                </td>
                                                                                            </tr>
                                                                                        </tbody>
                                                                                    </table>
                                                                            
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                            <div style="background:#E7E7E7;background-color:#E7E7E7;margin:0px auto;max-width:600px;">
                                                                <table align="center" border="0" cellpadding="0" cellspacing="0"
                                                                    role="presentation" style="background:#E7E7E7;background-color:#E7E7E7;width:100%;">
                                                                    <tbody>
                                                                        <tr>
                                                                            <td align="center" style="padding: 0;word-break:break-word;">
                                                                                <div
                                                                                    style="font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size: 12px;font-weight:400;line-height: 1.6;text-align:center;color: #a8a8a8;">
                                                                                    <br>
                                                                                    <a href="https://cedcommerce.com/" target="_blank"
                                                                                        style="color:#076482">www.cedcommerce.com</a>
                                                                                    <br>
                                                                                    <a href="https://support.cedcommerce.com/open.php" target="_blank"
                                                                                        style="color:#076482">Contact Support</a>
                                                                                </div>
                                                                                
                                                                                <div
                                                                                    style="font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size: 12px;font-weight:400;line-height: 1.6;text-align:center;color: #a8a8a8;">
                                                                                    <br>
                                                                                    © 2024 CedCommerce. All rights reserved.
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</body>
</html>