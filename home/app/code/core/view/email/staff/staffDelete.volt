<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staff Account Deletion</title>
</head>

<body style="background-color: #ffffff; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">

    <div style="background-color: #ffffff;">
        <!-- Your Email Content -->
        <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation"
            style="background:#ffffff; width:100%; max-width:600px; margin:0 auto;">
            <tbody>
                <tr>
                    <td>
                        <div style="margin: 0 auto; max-width: 600px;">
                            <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation"
                                style="width: 100%;">
                                <tbody>
                                    <tr>
                                        <td style="font-size: 0; text-align: center;">
                                            <div
                                                style="background: #E7E7E7; width: 100%; max-width: 600px; margin: 0 auto;">
                                                <table align="center" border="0" cellpadding="0" cellspacing="0"
                                                    role="presentation" style="background: #E7E7E7; width: 100%;">
                                                    <tbody>
                                                        <tr>
                                                            <td align="center" style="padding:0;word-break:break-word;">
                                                                <a href="https://cedcommerce.com/" title="Cedcommerce"
                                                                    target="_blank">
                                                                    <img alt="Cedcommerce" height="auto"
                                                                        src="https://i.imgur.com/nCgVOdk.png"
                                                                        style="border:0;display:block;outline:none;text-decoration:none;height:auto;width:100%;font-size:13px;background-color: #071042;"
                                                                        width="600">
                                                                </a>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <div
                                                style="background: #ffffff; width: 100%; max-width: 600px; margin: 0 auto;">
                                                <table border="0" cellpadding="0" cellspacing="0" role="presentation"
                                                    style="width: 100%;">
                                                    <tbody>
                                                        <tr>
                                                            <td style="padding: 25px;">
                                                                <h2
                                                                    style="font-size: 20px; font-weight: 500; line-height: 24px; margin: 0 0 10px; color: #000000;">
                                                                    Staff Account Deletion</h2>
                                                                <p
                                                                    style="font-size: 16px; font-weight: 400; line-height: 24px; margin: 0 0 15px; color: #000000;">
                                                                    Dear {{name}},</p>
                                                                <p
                                                                    style="font-size: 14px; font-weight: 400; line-height: 24px; margin: 0 0 15px; color: #000000;">
                                                                    Your staff account associated with the seller has
                                                                    been deleted.</p>
                                                                <p
                                                                    style="font-size: 14px; font-weight: 400; line-height: 24px; margin: 0 0 15px; color: #000000;">
                                                                    If you have any questions or need further
                                                                    assistance, please feel free to contact us.</p>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <div
                                                style="background: #E7E7E7; width: 100%; max-width: 600px; margin: 0 auto;">
                                                <table border="0" cellpadding="0" cellspacing="0" role="presentation"
                                                    style="width: 100%;">
                                                    <tbody>
                                                        <tr>
                                                            <td style="padding: 20px; text-align: center;">
                                                                <p
                                                                    style="font-size: 14px; font-weight: 400; line-height: 24px; margin: 0; color: #9da3a3;">
                                                                    Questions? We're here to help. Visit our <a
                                                                        href="https://support.cedcommerce.com/open.php"
                                                                        style="color: #076482; text-decoration: none;">Help
                                                                        Center</a>.</p>
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td style="padding: 10px 20px; text-align: center;">
                                                                <p
                                                                    style="font-size: 12px; font-weight: 400; line-height: 1.6; margin: 0; color: #a8a8a8;">
                                                                    &copy; 2024 CedCommerce. All rights reserved.</p>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</body>

</html>