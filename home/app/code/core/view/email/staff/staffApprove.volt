                                            <div
                                                style="font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;font-size:14px;font-weight:400;line-height:24px;text-align:left;color:#000000;">
                                                <p style="margin: 0;">
                                                    Dear {{name}},
                                                </p>
                                                <p style="margin: 0;">
                                                    Your request to join the seller's staff has been approved. You can
                                                    now access the seller's widget from seller central.
                                                </p>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
